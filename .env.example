# ============================================================
# CARA-X Environment Configuration
# Copy to .env and fill in your values
# ============================================================

# --- LLM Provider (Groq) ---
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# --- Neo4j (Optional — system uses in-memory by default) ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=cara_x_2026
NEO4J_ENABLED=false

# --- Qdrant (Optional — system uses in-memory by default) ---
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_ENABLED=false

# --- FastAPI ---
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true
LOG_LEVEL=INFO

# --- CARA-X Engine ---
CONSOLIDATION_INTERVAL_SECONDS=300
CONSOLIDATION_CONFIDENCE_THRESHOLD=0.7
CONSOLIDATION_MIN_OCCURRENCES=3
EPISODIC_DECAY_HOURS=72
MAX_EPISODIC_MEMORIES=10000
METACOGNITION_TRACKING=true

# --- Safety ---
SANDBOX_MODE=true
HUMAN_IN_THE_LOOP=true
CONFIDENCE_THRESHOLD_FOR_ACTION=0.8
